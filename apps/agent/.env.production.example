# Copy to apps/agent/.env.production before building the production DMG.
# electron-vite bakes MAIN_VITE_* into the main-process bundle at build time —
# this is how the shipped app learns where the API lives (a packaged app has
# no process.env). Point it at the deployed Render API, no trailing slash.
MAIN_VITE_API_URL=https://grind-api.onrender.com
