{
  "name": "@grind/agent",
  "version": "0.0.2-beta.9",
  "private": true,
  "type": "module",
  "description": "Grind time tracker desktop agent",
  "author": "RelicWave Technologies",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "icon": "node scripts/make-icon.mjs",
    "package": "pnpm package:mac:arm64",
    "package:unsigned": "pnpm package:mac:unsigned:arm64",
    "package:mac:arm64": "SIGN=1 bash scripts/package-mac.sh arm64",
    "package:mac:x64": "SIGN=1 bash scripts/package-mac.sh x64",
    "package:mac:universal": "SIGN=1 bash scripts/package-mac.sh universal",
    "package:mac:unsigned:arm64": "bash scripts/package-mac.sh arm64",
    "package:mac:unsigned:x64": "bash scripts/package-mac.sh x64",
    "package:mac:unsigned:universal": "bash scripts/package-mac.sh universal",
    "package:win": "node scripts/package-windows.mjs x64",
    "package:win:x64": "node scripts/package-windows.mjs x64"
  },
  "dependencies": {
    "@tanstack/react-query": "5.59.16",
    "better-sqlite3": "11.5.0",
    "color-name": "1.1.4",
    "electron-updater": "6.8.9",
    "lucide-react": "0.454.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "0.33.5",
    "uiohook-napi": "1.5.4",
    "ulid": "2.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^4.0.4",
    "@grind/core": "workspace:*",
    "@grind/tsconfig": "workspace:*",
    "@grind/types": "workspace:*",
    "@types/better-sqlite3": "7.6.11",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "cross-env": "^7.0.3",
    "electron": "33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "2.3.0",
    "typescript": "5.6.3",
    "vite": "5.4.10",
    "vitest": "2.1.4"
  },
  "optionalDependencies": {
    "get-windows": "9.2.0"
  }
}
