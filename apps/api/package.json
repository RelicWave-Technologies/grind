{
  "name": "@grind/api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.cjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --target node20 --clean --out-dir dist",
    "start": "node dist/index.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@grind/db": "workspace:*",
    "@grind/types": "workspace:*",
    "argon2": "0.41.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.1",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "pino-pretty": "11.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@grind/tsconfig": "workspace:*",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.16.13",
    "tsup": "8.3.5",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
