{
  "name": "grind",
  "private": true,
  "version": "0.0.0",
  "description": "Internal time tracker + screenshot monitor",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.18 <21"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @grind/db exec prisma generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @grind/db exec prisma migrate dev",
    "db:deploy": "dotenv -e .env -- pnpm --filter @grind/db exec prisma migrate deploy",
    "db:seed": "dotenv -e .env -- pnpm --filter @grind/db exec tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env -- pnpm --filter @grind/db exec prisma studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.12.2",
    "@typescript-eslint/parser": "8.12.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "9.13.0",
    "turbo": "2.2.3",
    "typescript": "5.6.3",
    "typescript-eslint": "8.12.2"
  }
}
