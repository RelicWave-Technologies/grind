{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env"],
  "globalPassThroughEnv": ["AGENT_API_URL", "AGENT_IDLE_SEC", "NODE_ENV"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^db:generate"]
    },
    "db:generate": {
      "outputs": ["node_modules/.prisma/**", "../../node_modules/.prisma/**"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "outputs": ["dist/**", "out/**"]
    },
    "typecheck": {
      "dependsOn": ["^db:generate"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^db:generate"],
      "outputs": [],
      "cache": false
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
