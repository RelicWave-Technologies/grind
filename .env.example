# --- Database (Neon Postgres) ---
# Pooled URL (used at runtime by API). Note: pgbouncer=true disables prepared statements.
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/grind?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct URL (used by `prisma migrate`). pgbouncer can't handle advisory locks / DDL.
DIRECT_URL="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/grind?sslmode=require"

# --- API ---
API_PORT=4000
NODE_ENV=development
# Generate with: openssl rand -base64 32
JWT_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_32"
JWT_ACCESS_TTL_SECONDS=900       # 15 minutes
JWT_REFRESH_TTL_SECONDS=2592000  # 30 days

# --- Agent ---
# Where the Electron agent looks for the API. Override per-machine via env var or .env.local.
AGENT_API_URL="http://localhost:4000"

# --- Cloudinary (screenshot storage) ---
# When all three are set, the API signs direct uploads from the agent and the
# agent pushes screenshots to Cloudinary. Leave unset to keep shots local-only.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Folder screenshots land in (optional; defaults to grind/screenshots).
CLOUDINARY_FOLDER="grind/screenshots"

# Public origin of the deployed dashboard (used for CORS + cross-site cookies).
# e.g. https://grind-dashboard.vercel.app
DASHBOARD_URL=""

# --- Lark / Feishu integration (optional) ---
# Leave unset to run with Lark disabled (the API degrades gracefully).
# Create a custom internal app in the Lark Developer Console, enable Bot +
# Interactive Card, and grant the scopes listed in apps/api/src/lark/config.ts.
LARK_APP_ID=""
LARK_APP_SECRET=""
# 32-byte key that encrypts OAuth refresh tokens at rest. REQUIRED if the two
# above are set. Generate with: openssl rand -base64 32
LARK_TOKEN_KEY=""
# OAuth v2 hosts (international tenant defaults shown; use feishu.cn for China).
LARK_OAUTH_HOST="https://open.larksuite.com"
LARK_ACCOUNTS_HOST="https://accounts.larksuite.com"
# Where Lark redirects after the user authorizes (must match the console config).
LARK_OAUTH_REDIRECT_URI="http://localhost:4000/v1/lark/oauth/callback"
