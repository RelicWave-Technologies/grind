generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users User[]
  teams Team[]
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  MEMBER
}

/// A team groups MEMBERs under a MANAGER. Manager-scoped queries
/// (timesheets, approvals, screenshots) only return rows whose user
/// belongs to a team the caller manages. Optional — workspaces can
/// continue to operate flat (everyone MEMBER → admins see all).
model Team {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  managerId   String?
  manager     User?     @relation("TeamManager", fields: [managerId], references: [id], onDelete: SetNull)
  members     User[]    @relation("TeamMembers")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([managerId])
}

model User {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  email        String   @unique
  name         String
  role         Role     @default(MEMBER)
  /// Optional team this user belongs to. NULL = workspace-level (no team
  /// scoping applies; admin sees them, no manager does).
  teamId       String?
  team         Team?    @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)
  /// Denormalised pointer to the user's direct manager (= their team's
  /// managerId, kept in sync on team updates). Lets us answer "who
  /// manages me?" with a single FK lookup, no join.
  managerId    String?
  passwordHash String
  createdAt    DateTime @default(now())

  refreshTokens   RefreshToken[]
  timeEntries     TimeEntry[]
  activitySamples ActivitySample[]
  larkIdentity    LarkIdentity?
  larkOAuthToken  LarkOAuthToken?
  manualTimeRequests       ManualTimeRequest[] @relation("MtrRequester")
  manualTimeApprovals      ManualTimeRequest[] @relation("MtrApprover")
  managedTeams             Team[]              @relation("TeamManager")

  @@index([workspaceId])
  @@index([teamId])
  @@index([managerId])
}

enum TimeEntrySource {
  AUTO
  MANUAL
}

enum SegmentKind {
  WORK
  MEETING
  IDLE_TRIMMED
}

model TimeEntry {
  id           String          @id // ULID from agent
  clientUuid   String          @unique // idempotency key
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  /// Lark task this entry is attributed to (or null for an untagged session).
  /// The "project" / local Task concepts were removed — tasks are Lark-only now.
  larkTaskGuid String?
  source       TimeEntrySource @default(AUTO)
  startedAt    DateTime
  endedAt      DateTime?
  /// Free-form user-facing note ("emails", "design review", "fixed bug X").
  /// Shown in the Edit Time table's Reason column. Editable inline; doesn't
  /// require approver review because it's metadata, not new tracked time.
  notes        String?
  agentVersion String?
  platform     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  segments        TimeSegment[]
  activitySamples ActivitySample[]
  manualTimeRequest ManualTimeRequest?

  @@index([userId, startedAt])
  @@index([larkTaskGuid])
}

model TimeSegment {
  id          String      @id // ULID from agent
  timeEntryId String
  timeEntry   TimeEntry   @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  kind        SegmentKind @default(WORK)
  startedAt   DateTime
  endedAt     DateTime?

  @@index([timeEntryId])
}

model ActivitySample {
  id              String    @id // ULID from agent
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  timeEntryId     String?
  timeEntry       TimeEntry? @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  bucketStart     DateTime // 1-minute bucket
  keystrokes      Int
  clicks          Int
  mouseDistancePx Int
  scrollEvents    Int
  // content-free anti-cheat signals (no key identity / content)
  ikiCv           Float?
  moveSpeedCv     Float?
  pathStraightness Float?
  createdAt       DateTime  @default(now())

  @@unique([userId, bucketStart])
  @@index([userId, bucketStart])
  @@index([timeEntryId])
}

/// Maps a Grind user to their Lark identity. Resolved once (email -> open_id)
/// via contact/v3/users/batch_get_id using a tenant token.
model LarkIdentity {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  openId     String   @unique // per-app identifier (open_id)
  unionId    String? // cross-app identifier within the Lark org
  userIdLark String? // tenant-scoped user_id (requires extra scope)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([openId])
}

/// Per-user Lark OAuth tokens. The refresh token is encrypted at rest and is
/// SINGLE-USE (7-day TTL): each refresh rotates it and the new value must be
/// persisted in the SAME transaction before the access token is used.
/// On any refresh failure, set reauthRequired=true and surface "reconnect Lark".
model LarkOAuthToken {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenEnc   String // AES-256-GCM ciphertext (iv:tag:data, base64url)
  refreshExpiresAt  DateTime
  scopes            String // space-delimited granted scopes
  reauthRequired    Boolean   @default(false)
  lastRefreshedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum ManualTimeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// A user-submitted request to log time after the fact. Sent to a workspace
/// approver (admin / manager) via a Lark IM interactive card; the manager's
/// click flips status here and (on APPROVE) creates a TimeEntry(source=MANUAL).
model ManualTimeRequest {
  id             String                  @id @default(cuid())
  clientUuid     String                  @unique // idempotency key from the agent
  userId         String
  user           User                    @relation("MtrRequester", fields: [userId], references: [id])
  larkTaskGuid   String?
  requestedStart DateTime
  requestedEnd   DateTime
  reason         String
  status         ManualTimeRequestStatus @default(PENDING)
  approverId     String?
  approver       User?                   @relation("MtrApprover", fields: [approverId], references: [id])
  larkMessageId  String?                 // id of the IM card we sent, for in-place update
  decidedAt      DateTime?
  decidedReason  String?                 // optional approver note
  /// FK to the TimeEntry created on APPROVE (null until decided / on reject).
  timeEntryId    String?                 @unique
  timeEntry      TimeEntry?              @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([userId, status])
  @@index([approverId, status])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String    @unique
  deviceName String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}
