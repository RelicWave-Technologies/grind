generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  /// Canonical business-calendar timezone. Stored event timestamps remain UTC.
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())

  users          User[]
  teams          Team[]
  teamManagers   TeamManager[]
  shifts         Shift[]
  policy         WorkspacePolicy?
  payrollPolicy  PayrollPolicy?
  payrollRunLogs PayrollRunLog[]
  timeInvalidations TimeInvalidation[]
  monitoringSettingsAudits MonitoringSettingsAudit[]
  testerOpsConfig TesterOpsConfig?
  testerOpsAiPolicy TesterOpsAiPolicy?
  testerOpsMembers TesterOpsMember[]
  testerOpsEvents TesterOpsEvent[]
  testerOpsIssues TesterOpsIssue[]
  testerOpsReminders TesterOpsReminder[]
  testerOpsOutboxEvents TesterOpsOutboxEvent[]
  testerOpsKnowledgeSources TesterOpsKnowledgeSource[]
  testerOpsAiRuns TesterOpsAiRun[]
  apiTokens ApiToken[]
}

/// Workspace-wide capture policy. A single row per workspace (unique on
/// workspaceId) — created on demand the first time the admin opens the
/// policy editor. Defaults are PRIVACY-CONSCIOUS: titles + URLs OFF,
/// apps OFF. ADMIN flips them on. Surface name + bundle without title
/// (which app, not which document); URLs require the explicit URL flag
/// since URLs are content.
///
/// 60-day screenshot retention is enforced by a scheduled API job that
/// soft-deletes expired Screenshot rows and trashes their storage objects;
/// setting it to 0 disables retention (every shot kept forever —
/// generally not what we want).
model WorkspacePolicy {
  id                         String   @id @default(cuid())
  workspaceId                String   @unique
  workspace                  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /// Capture which app is in focus per ActivitySample (process / bundle id).
  captureApps                Boolean  @default(false)
  /// Capture the foreground window title (TIGHTER than apps — leaks doc names).
  captureTitles              Boolean  @default(false)
  /// Capture the browser URL (TIGHTEST — content).
  captureUrls                Boolean  @default(false)
  /// Days to retain screenshots before the nightly purge deletes them.
  retentionDaysScreenshots   Int      @default(60)
  /// Workspace default screenshot cadence for newly-created members.
  /// Per-member overrides live on User.screenshotIntervalMin.
  defaultScreenshotIntervalMin Int     @default(3)
  /// Workspace default idle threshold for newly-created members.
  /// Per-member overrides live on User.idleThresholdMin.
  defaultIdleThresholdMin     Int      @default(5)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

enum PayrollSheetRecipientMode {
  ALL_ADMINS
}

/// Admin-owned payroll classification settings. This is intentionally
/// separate from WorkspacePolicy because payroll is a derived finance
/// worksheet, while WorkspacePolicy controls capture/privacy behavior.
model PayrollPolicy {
  id                   String                    @id @default(cuid())
  workspaceId          String                    @unique
  workspace            Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  halfDayLowerMin      Int                       @default(240)
  halfDayUpperMin      Int                       @default(480)
  fullDayLowerMin      Int                       @default(480)
  fullDayUpperMin      Int                       @default(600)
  monthlyLowerMin      Int                       @default(9600)
  timezone             String                    @default("UTC")
  approvalReminderDays Int[]                     @default([3, 4])
  approvalReminderTime String                    @default("00:00")
  payrollSheetSendDay  Int                       @default(5)
  payrollSheetSendTime String                    @default("00:00")
  sendPayrollSheetTo   PayrollSheetRecipientMode @default(ALL_ADMINS)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
}

enum PayrollRunType {
  APPROVAL_REMINDER
  PAYROLL_SHEET
}

enum PayrollRunStatus {
  SENT
  PARTIAL
  FAILED
  SKIPPED
}

/// One row per scheduled month-close send. The unique key is the
/// idempotency boundary so API restarts do not resend Lark reminders or
/// payroll sheets for the same workspace/month/scheduled instant.
model PayrollRunLog {
  id                     String           @id @default(cuid())
  workspaceId            String
  workspace              Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  month                  String
  runType                PayrollRunType
  scheduledFor           DateTime
  status                 PayrollRunStatus
  sentCount              Int              @default(0)
  skippedNoLarkCount     Int              @default(0)
  skippedUnassignedCount Int              @default(0)
  failedCount            Int              @default(0)
  errors                 Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@unique([workspaceId, month, runType, scheduledFor])
  @@index([workspaceId, month])
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum ActivityRoleTitle {
  DEVELOPER
  DESIGNER
  SALES
  OTHER
}

enum MonitoringSettingsScope {
  WORKSPACE_POLICY
  MEMBER_OVERRIDE
}

enum MonitoringSettingsRiskLevel {
  NORMAL
  CAUTION
  HIGH
}

enum AgentRuntimeState {
  IDLE
  RUNNING
  PAUSED_IDLE
  PAUSED_PERMISSION
  OFFLINE
}

/// A team is a home grouping for time totals. Management is modeled by
/// TeamManager so a team can have multiple managers while each manager owns
/// at most one team.
model Team {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  members     User[]    @relation("TeamMembers")
  managers    TeamManager[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

/// Team management assignment. Product rule for v1: one team can have many
/// managers, but one user can manage only one team. A non-admin user's
/// workspace role is derived from this table.
model TeamManager {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([teamId, userId])
  @@unique([userId])
  @@index([workspaceId])
  @@index([teamId])
}

/// A workspace-defined work schedule (e.g. "Day Shift", "Night Shift").
/// `schedule` is a JSON object keyed by lowercase weekday with optional
/// per-day start/end times in the user's LOCAL timezone (HH:MM 24-hour).
/// A day with `null` means off (no shift that day → no popup).
///
/// Shape (validated at API layer via @grind/types Shift schema):
///   { mon: { start: "09:00", end: "18:00" } | null,
///     tue: ..., wed: ..., thu: ..., fri: ...,
///     sat: null, sun: null }
///
/// `bufferMin` is the cushion after a shift's start during which the
/// agent's "ready to work?" popup keeps nudging the user every 5 min.
/// After `start + bufferMin`, the popup stops bothering for that day.
///
/// Forward-only assignment: changing a user's shift does NOT rewrite past
/// TimeEntries; each entry snapshots `shiftIdAtStart` at creation time.
model Shift {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  /// See model-comment for the shape; validated by @grind/types.
  schedule    Json
  bufferMin   Int      @default(30)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members User[] @relation("ShiftMembers")

  @@index([workspaceId])
}

model User {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  email        String   @unique
  name         String
  role         Role     @default(MEMBER)
  /// Optional team this user belongs to. NULL = workspace-level (no team
  /// scoping applies; admin sees them, no manager does).
  teamId       String?
  team         Team?    @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)
  /// Deprecated: old direct-manager pointer. v1 org scope and manual-time
  /// approval now resolve through TeamManager + User.teamId.
  managerId    String?
  /// Legacy email/password hash. NULLABLE: Lark OAuth is the sole identity in
  /// production, so Lark-provisioned users never have one. Retained (not
  /// dropped) so a dev-only password login shim and a clean revert path remain.
  passwordHash String?
  /// JIT provisioning gate. First Lark login creates the user as PENDING (no
  /// session issued) until an admin completes setup or activates access. The
  /// configured bootstrap admin is created ACTIVE. Distinct from deactivatedAt,
  /// which means "was active, now disabled".
  provisioningStatus ProvisioningStatus @default(PENDING)
  /// Avatar URL synced from Lark on each login (stable profile field).
  avatarUrl    String?
  /// Activity scoring preset. Admin-owned so users cannot self-tune KPI output.
  activityRoleTitle ActivityRoleTitle @default(OTHER)
  /// Soft-deactivation: when non-null, the user can't log in, doesn't
  /// appear in scope/admin queries, and (importantly) their *history*
  /// remains queryable for back-dated reports + audit. Reactivation
  /// just clears this timestamp. We intentionally never hard-delete
  /// users — every TimeEntry / approval / flag still points at them.
  deactivatedAt DateTime?
  createdAt    DateTime @default(now())

  /// Currently-assigned shift. Forward-only: changing this does NOT
  /// rewrite history; each TimeEntry snapshots `shiftIdAtStart` so reports
  /// remain truthful even after a reassignment.
  shiftId          String?
  shift            Shift?    @relation("ShiftMembers", fields: [shiftId], references: [id], onDelete: SetNull)
  shiftAssignedAt  DateTime?
  /// Per-member screenshot-cadence OVERRIDE in minutes. NULL = inherit the
  /// workspace policy default (WorkspacePolicy.defaultScreenshotIntervalMin).
  /// A value is an explicit per-member override set by an admin/manager.
  screenshotIntervalMin Int?
  /// Per-member idle-threshold OVERRIDE in minutes. NULL = inherit the
  /// workspace policy default (WorkspacePolicy.defaultIdleThresholdMin).
  idleThresholdMin      Int?
  /// Optional early idle warning for this member, in seconds. NULL means the
  /// countdown is disabled. Admins own this setting; the idle threshold still
  /// controls when tracked time is actually paused.
  idleWarningSeconds    Int?
  /// Last heartbeat received from the desktop agent. Overview uses this as the
  /// live-status source of truth instead of inferring "green" from open rows.
  agentLastSeenAt       DateTime?
  agentState            AgentRuntimeState @default(OFFLINE)
  agentVersion          String?
  agentPlatform         String?
  agentActiveEntryId    String?
  /// Last known local desktop permission health from agent heartbeat.
  /// Nullable so older agents keep heartbeating and show as Unknown in admin UI.
  agentScreenPermissionStatus   String?
  agentScreenCaptureHealth      String?
  agentScreenPermissionState    String?
  agentAccessibilityTrusted     Boolean?
  agentAccessibilityReady       Boolean?
  agentAccessibilityRecording   Boolean?
  agentAccessibilityCapturing   Boolean?
  agentAccessibilityHookRunning Boolean?
  agentPermissionsUpdatedAt     DateTime?
  /// Last-known launch-at-login health. Nullable for older desktop agents.
  agentLaunchAtLoginState       String?
  agentLaunchOrigin             String?
  agentLaunchAtLoginUpdatedAt   DateTime?

  refreshTokens   RefreshToken[]
  timeEntries     TimeEntry[]
  activitySamples ActivitySample[]
  shiftAssignments ShiftAssignment[]
  screenshots      Screenshot[]        @relation("ScreenshotSubject")
  deletedScreenshots Screenshot[]      @relation("ScreenshotDeletedBy")
  larkIdentity    LarkIdentity?
  larkOAuthToken  LarkOAuthToken?
  agentAuthCodes  AgentAuthCode[]
  manualTimeRequests       ManualTimeRequest[] @relation("MtrRequester")
  manualTimeApprovals      ManualTimeRequest[] @relation("MtrApprover")
  manualTimeDecisions      ManualTimeRequest[] @relation("MtrDecider")
  managedTeamAssignment    TeamManager?
  activityFlags            ActivityFlag[]      @relation("FlagSubject")
  resolvedFlags            ActivityFlag[]      @relation("FlagResolver")
  timeInvalidations        TimeInvalidation[]  @relation("TimeInvalidationSubject")
  timeInvalidationsCreated TimeInvalidation[]  @relation("TimeInvalidationActor")
  monitoringSettingsAuditsCreated MonitoringSettingsAudit[] @relation("MonitoringSettingsAuditActor")
  monitoringSettingsAuditsTargeted MonitoringSettingsAudit[] @relation("MonitoringSettingsAuditTarget")
  testerOpsMemberships TesterOpsMember[]
  testerOpsReportedIssues TesterOpsIssue[] @relation("TesterOpsReporter")
  /// Attendee relations: meetings this user was tagged in (manual-time
  /// requests + live MEETING TimeEntries). Useful for "show me everyone's
  /// meetings I was in" reports.
  mtrAttendances           MtrAttendee[]       @relation("MtrAttendeeUser")
  timeEntryAttendances     TimeEntryAttendee[] @relation("TeAttendeeUser")
  createdApiTokens         ApiToken[]          @relation("ApiTokenCreator")

  @@index([workspaceId])
  @@index([teamId])
  @@index([managerId])
  @@index([shiftId])
  @@index([workspaceId, agentState, agentLastSeenAt])
}

model ApiToken {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("ApiTokenCreator", fields: [createdById], references: [id], onDelete: Cascade)
  name        String
  publicId    String    @unique
  tokenPrefix String
  tokenHash   String    @unique
  scopes      String[]  @default([])
  lastUsedAt  DateTime?
  lastUsedIp  String?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, revokedAt])
  @@index([createdById])
}

/// Historical shift assignment snapshots. User.shiftId is the current
/// assignment for fast reads; this table is the audit source for back-dated
/// reports, because shifts can be edited or users can be reassigned later.
model ShiftAssignment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftId           String?
  effectiveFrom     DateTime @default(now())
  effectiveTo       DateTime?
  shiftNameSnapshot String?
  scheduleSnapshot  Json?
  bufferMinSnapshot Int?
  createdAt         DateTime @default(now())

  @@index([userId, effectiveFrom])
  @@index([userId, effectiveTo])
}

enum TimeEntrySource {
  AUTO
  MANUAL
}

enum SegmentKind {
  WORK
  MEETING
  IDLE_TRIMMED
}

enum TimeEntryCloseReason {
  AGENT
  AGENT_RECOVERY
  LEASE_EXPIRED
  SUPERSEDED
  LEGACY_RECONCILED
}

model TimeEntry {
  id           String          @id // ULID from agent
  clientUuid   String          @unique // idempotency key
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  /// Lark task this entry is attributed to (or null for an untagged session).
  /// The "project" / local Task concepts were removed — tasks are Lark-only now.
  larkTaskGuid String?
  source       TimeEntrySource @default(AUTO)
  startedAt    DateTime
  endedAt      DateTime?
  /// Versioned agent/server lifecycle protocol. NULL means a legacy agent.
  trackingProtocolVersion Int?
  /// Monotonic local timer mutation revision. Used to reject delayed syncs.
  agentRevision Int?
  /// Latest client checkpoint accepted by the server, clamped to server time.
  lastProvenAt DateTime?
  /// Server-time lease deadline. Only protocol-v2 entries are auto-finalized.
  leaseExpiresAt DateTime?
  closeReason TimeEntryCloseReason?
  /// Audit timestamp for server-side finalization/reconciliation.
  serverFinalizedAt DateTime?
  /// Free-form user-facing note ("emails", "design review", "fixed bug X").
  /// Shown in the Edit Time table's Reason column. Editable inline; doesn't
  /// require approver review because it's metadata, not new tracked time.
  notes        String?
  agentVersion String?
  platform     String?
  /// Snapshot of the user's `shiftId` at the moment this TimeEntry started.
  /// Lets reports answer "what shift was Anish on the morning of 2026-06-15"
  /// even after he's been reassigned. No FK to Shift — we preserve the id
  /// string for audit even if the shift row itself is later deleted.
  shiftIdAtStart String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  segments        TimeSegment[]
  activitySamples ActivitySample[]
  manualTimeRequest ManualTimeRequest?
  /// Workspace members the requester (or a later retro-tag on a live
  /// MEETING segment) said were in this meeting. Only populated for
  /// blocks that include at least one MEETING segment.
  attendees       TimeEntryAttendee[]
  screenshots     Screenshot[]

  @@index([userId, startedAt])
  @@index([larkTaskGuid])
  @@index([trackingProtocolVersion, endedAt, leaseExpiresAt])
}

enum ScreenshotUploadState {
  PENDING
  UPLOADED
  FAILED
}

model Screenshot {
  id            String                @id
  userId        String
  user          User                  @relation("ScreenshotSubject", fields: [userId], references: [id], onDelete: Cascade)
  timeEntryId   String?
  timeEntry     TimeEntry?            @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  displayId     String?
  capturedAt    DateTime
  s3Key         String?
  thumbS3Key    String?
  fullUrl       String?
  thumbUrl      String?
  bytes         Int?
  width         Int?
  height        Int?
  phash         BigInt?
  uploadState   ScreenshotUploadState @default(PENDING)
  blurred       Boolean               @default(false)
  deletedAt     DateTime?
  deletedById   String?
  deletedBy     User?                 @relation("ScreenshotDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedReason String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([userId, capturedAt])
  @@index([timeEntryId])
}

model TimeSegment {
  id          String      @id // ULID from agent
  timeEntryId String
  timeEntry   TimeEntry   @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  kind        SegmentKind @default(WORK)
  startedAt   DateTime
  endedAt     DateTime?

  @@index([timeEntryId])
}

model ActivitySample {
  id              String    @id // ULID from agent
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  timeEntryId     String?
  timeEntry       TimeEntry? @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  bucketStart     DateTime // 1-minute bucket
  keystrokes      Int
  clicks          Int
  mouseDistancePx Int
  scrollEvents    Int
  // content-free anti-cheat signals (no key identity / content)
  ikiCv           Float?
  moveSpeedCv     Float?
  pathStraightness Float?

  // Active app + site for the dominant minute. Captured only when the
  // workspace policy allows; otherwise stays null. The agent computes the
  // dominant app over the minute window and snaps the title/URL of the
  // window that was focused longest. Title/URL are gated by SEPARATE
  // policy flags — apps without titles is the calm default.
  activeApp       String?  // human-readable app name (e.g. "Google Chrome")
  activeAppBundle String?  // OS bundle / process identifier
  activeTitle     String?  // foreground window title (policy-gated)
  activeUrl       String?  // browser URL (policy-gated; tighter than title)

  createdAt       DateTime  @default(now())

  @@unique([userId, bucketStart])
  @@index([userId, bucketStart])
  @@index([timeEntryId])
  @@index([userId, activeApp])
}

/// Maps a Grind user to their Lark identity. Resolved once (email -> open_id)
/// via contact/v3/users/batch_get_id using a tenant token.
model LarkIdentity {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  openId     String   @unique // per-app identifier (open_id)
  unionId    String? // cross-app identifier within the Lark org
  userIdLark String? // tenant-scoped user_id (requires extra scope)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([openId])
}

/// Per-user Lark OAuth tokens. The refresh token is encrypted at rest and is
/// SINGLE-USE (7-day TTL): each refresh rotates it and the new value must be
/// persisted in the SAME transaction before the access token is used.
/// On any refresh failure, set reauthRequired=true and surface "reconnect Lark".
model LarkOAuthToken {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenEnc   String // AES-256-GCM ciphertext (iv:tag:data, base64url)
  refreshExpiresAt  DateTime
  scopes            String // space-delimited granted scopes
  reauthRequired    Boolean   @default(false)
  lastRefreshedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

/// JIT-provisioning lifecycle for Lark-authenticated users.
enum ProvisioningStatus {
  PENDING // created on first Lark login; no session until setup or activation
  ACTIVE  // admin completed setup/activated access (or bootstrap admin); may sign in
}

/// Short-lived, single-use handoff codes for the DESKTOP AGENT's Lark login.
/// The system-browser OAuth callback redirects to timo://auth?code=<one-time>;
/// the agent redeems it at /v1/auth/lark/exchange with its PKCE verifier. We
/// never put long-lived tokens in the custom-scheme URL, and the code is
/// useless without the verifier (blocks another local app intercepting the
/// scheme). Plaintext is never stored — only sha256(code).
model AgentAuthCode {
  id         String    @id @default(cuid())
  codeHash   String    @unique // sha256 of the one-time code
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge  String // PKCE S256 challenge supplied by the agent at /start
  expiresAt  DateTime // now + 120s
  consumedAt DateTime? // single-use guard
  createdAt  DateTime  @default(now())

  @@index([userId])
}

enum ManualTimeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ManualTimeDecisionSource {
  LARK_CARD
  DASHBOARD
  REQUESTER_CANCEL
  MANAGER_CANCEL
  AUTO_APPROVE
  ADMIN_REOPEN
}

enum ManualTimeLarkMessageKind {
  APPROVAL
  UPDATED_APPROVAL
  DECIDED_NOTICE
}

enum ManualTimeLarkMessageStatus {
  PENDING
  SENT
  SEND_FAILED
  UPDATE_FAILED
  SUPERSEDED
  CANCELLED
  DECIDED
  STALE
}

enum ManualTimeLarkOutboxKind {
  SEND_CARD
  SUPERSEDE_OLD_CARDS
  FINALIZE_CARDS
}

enum ManualTimeLarkOutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

/// A user-submitted request to log time after the fact. Sent to a workspace
/// approver (admin / manager) via a Lark IM interactive card; the manager's
/// click flips status here and (on APPROVE) creates a TimeEntry(source=MANUAL).
model ManualTimeRequest {
  id             String                  @id @default(cuid())
  clientUuid     String                  @unique // idempotency key from the agent
  userId         String
  user           User                    @relation("MtrRequester", fields: [userId], references: [id])
  larkTaskGuid   String?
  /// Human task label captured at request time. Lark GUIDs are durable
  /// references, but not readable enough for historical approval rows.
  taskSummary    String?
  requestedStart DateTime
  requestedEnd   DateTime
  reason         String
  status         ManualTimeRequestStatus @default(PENDING)
  version        Int                     @default(1)
  approverId     String?
  approver       User?                   @relation("MtrApprover", fields: [approverId], references: [id])
  decidedById    String?
  decidedBy      User?                   @relation("MtrDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  decisionSource ManualTimeDecisionSource?
  larkMessageId  String?                 // id of the IM card we sent, for in-place update
  decidedAt      DateTime?
  decidedReason  String?                 // optional approver note
  /// FK to the TimeEntry created on APPROVE (null until decided / on reject).
  timeEntryId    String?                 @unique
  timeEntry      TimeEntry?              @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  /// True when the request was auto-approved by the requester themselves
  /// (their role was MANAGER+ and policy allows). Distinguishes from a
  /// human approver in the audit trail. Admins can REOPEN auto-approved
  /// requests within 24h via /v1/admin/time-requests/:id/reopen.
  autoApproved   Boolean                 @default(false)
  /// Meeting attendees (workspace members the requester says were in
  /// this meeting). Propagated to TimeEntryAttendee on approval.
  attendees      MtrAttendee[]
  larkMessages   ManualTimeLarkMessage[]
  larkOutboxEvents ManualTimeLarkOutboxEvent[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([userId, status])
  @@index([approverId, status])
  @@index([status, version])
}

model ManualTimeLarkMessage {
  id              String                      @id @default(cuid())
  requestId       String
  request         ManualTimeRequest           @relation(fields: [requestId], references: [id], onDelete: Cascade)
  version         Int
  recipientOpenId String
  messageId       String?                     @unique
  kind            ManualTimeLarkMessageKind
  status          ManualTimeLarkMessageStatus @default(PENDING)
  attempts        Int                         @default(0)
  lastError       String?
  sentAt          DateTime?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  outboxEvents    ManualTimeLarkOutboxEvent[]

  @@index([requestId, version])
  @@index([requestId, status])
  @@index([status, updatedAt])
}

model ManualTimeLarkOutboxEvent {
  id              String                       @id @default(cuid())
  requestId       String
  request         ManualTimeRequest            @relation(fields: [requestId], references: [id], onDelete: Cascade)
  messageLedgerId String?
  messageLedger   ManualTimeLarkMessage?       @relation(fields: [messageLedgerId], references: [id], onDelete: SetNull)
  kind            ManualTimeLarkOutboxKind
  status          ManualTimeLarkOutboxStatus   @default(PENDING)
  payload         Json                         @default("{}")
  attempts        Int                          @default(0)
  nextRunAt       DateTime                     @default(now())
  lockedAt        DateTime?
  lockedBy        String?
  lastError       String?
  processedAt     DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  @@index([status, nextRunAt, createdAt])
  @@index([requestId])
  @@index([messageLedgerId])
}

enum TesterOpsAiProvider {
  OPENROUTER
  DEEPSEEK
}

enum TesterOpsEventSource {
  LARK_EVENT
  HISTORY_POLL
  MANUAL_REPLAY
}

enum TesterOpsEventStatus {
  PENDING
  PROCESSED
  IGNORED
  FAILED
}

enum TesterOpsIntent {
  ISSUE_REPORT
  DOC_QUESTION
  USAGE_STATUS
  PING_REQUEST
  GENERAL_HELP
  IRRELEVANT
}

enum TesterOpsSafeAction {
  NONE
  LOG_ISSUE
  ASK_CLARIFICATION
  ANSWER_FROM_DOCS
  ANSWER_GENERAL
  GET_USAGE_STATUS
  SEND_PING
  LIST_ISSUES
}

enum TesterOpsIssueStatus {
  CANDIDATE
  OPEN
  RESOLVED
  DISMISSED
}

enum TesterOpsIssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TesterOpsOutboxKind {
  SEND_TEXT
  SEND_CARD
}

enum TesterOpsOutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  DEAD_LETTER
}

model TesterOpsConfig {
  id                           String    @id @default(cuid())
  workspaceId                  String    @unique
  workspace                    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  enabled                      Boolean   @default(false)
  chatId                       String?
  timezone                     String    @default("UTC")
  pingTimes                    String[]  @default(["11:00", "17:00"])
  passiveIssueDetectionEnabled Boolean   @default(false)
  announcementSentAt           DateTime?
  pollCursor                   String?
  lastHistoryPollAt            DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt
}

model TesterOpsAiPolicy {
  id                        String              @id @default(cuid())
  workspaceId               String              @unique
  workspace                 Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider                  TesterOpsAiProvider @default(OPENROUTER)
  model                     String?
  promptVersion             String              @default("tester-ops-v1")
  temperature               Float               @default(0.1)
  highConfidenceThreshold   Float               @default(0.78)
  mediumConfidenceThreshold Float               @default(0.5)
  maxClarifyingQuestions    Int                 @default(1)
  allowedActions            String[]            @default(["NONE", "LOG_ISSUE", "ASK_CLARIFICATION", "ANSWER_FROM_DOCS", "ANSWER_GENERAL", "GET_USAGE_STATUS", "SEND_PING", "LIST_ISSUES"])
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
}

model TesterOpsMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  openId      String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  displayName String?
  isTester    Boolean   @default(true)
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  events TesterOpsEvent[]
  issues TesterOpsIssue[]

  @@unique([workspaceId, openId])
  @@index([workspaceId])
  @@index([userId])
}

model TesterOpsEvent {
  id           String               @id @default(cuid())
  workspaceId  String
  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source       TesterOpsEventSource
  sourceId     String
  chatId       String?
  messageId    String?
  senderOpenId String?
  memberId     String?
  member       TesterOpsMember?     @relation(fields: [memberId], references: [id], onDelete: SetNull)
  messageText  String
  raw          Json?
  status       TesterOpsEventStatus @default(PENDING)
  receivedAt   DateTime             @default(now())
  processedAt  DateTime?
  error        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  issues TesterOpsIssue[]
  aiRuns TesterOpsAiRun[]

  @@unique([workspaceId, source, sourceId])
  @@index([workspaceId, status, receivedAt])
  @@index([messageId])
}

model TesterOpsIssue {
  id                String                 @id @default(cuid())
  workspaceId       String
  workspace         Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  eventId           String?
  event             TesterOpsEvent?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  reporterMemberId  String?
  reporterMember    TesterOpsMember?       @relation(fields: [reporterMemberId], references: [id], onDelete: SetNull)
  reporterUserId    String?
  reporterUser      User?                  @relation("TesterOpsReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  reporterOpenId    String?
  status            TesterOpsIssueStatus   @default(CANDIDATE)
  intent            TesterOpsIntent        @default(ISSUE_REPORT)
  category          String?
  severity          TesterOpsIssueSeverity @default(LOW)
  confidence        Float                  @default(0)
  summary           String
  sourceMessageText String?
  sourceMessageId   String?
  clarifyingQuestion String?
  replyText         String?
  citations         Json?
  aiRunId           String?
  aiRun             TesterOpsAiRun?        @relation(fields: [aiRunId], references: [id], onDelete: SetNull)
  adminNote         String?
  resolvedAt        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([workspaceId, status, createdAt])
  @@index([eventId])
  @@index([reporterUserId])
}

model TesterOpsReminder {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scheduledFor  DateTime
  sentAt        DateTime?
  messageId     String?
  usageSnapshot Json      @default("{}")
  createdAt     DateTime  @default(now())

  @@unique([workspaceId, scheduledFor])
  @@index([workspaceId, sentAt])
}

model TesterOpsOutboxEvent {
  id             String                @id @default(cuid())
  workspaceId    String
  workspace      Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  kind           TesterOpsOutboxKind
  status         TesterOpsOutboxStatus @default(PENDING)
  idempotencyKey String                @unique
  chatId         String?
  openId         String?
  payload        Json                  @default("{}")
  attempts       Int                   @default(0)
  nextRunAt      DateTime              @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  lastError      String?
  messageId      String?
  processedAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([workspaceId, status, nextRunAt])
}

model TesterOpsKnowledgeSource {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title         String
  token         String
  url           String?
  enabled       Boolean   @default(true)
  lastFetchedAt DateTime?
  lastError     String?
  contentHash   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  chunks TesterOpsKnowledgeChunk[]

  @@unique([workspaceId, token])
  @@index([workspaceId, enabled])
}

model TesterOpsKnowledgeChunk {
  id          String                   @id @default(cuid())
  sourceId    String
  source      TesterOpsKnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  ordinal     Int
  title       String
  content     String
  contentHash String
  tokenCount  Int                      @default(0)
  metadata    Json?
  embedding   Json?
  createdAt   DateTime                 @default(now())

  @@unique([sourceId, ordinal])
  @@index([sourceId])
  @@index([contentHash])
}

model TesterOpsAiRun {
  id            String               @id @default(cuid())
  workspaceId   String
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  eventId       String?
  event         TesterOpsEvent?      @relation(fields: [eventId], references: [id], onDelete: SetNull)
  provider      String
  model         String
  promptVersion String
  task          String
  input         Json
  output        Json?
  safeAction    TesterOpsSafeAction?
  confidence    Float?
  latencyMs     Int?
  error         String?
  createdAt     DateTime             @default(now())

  issues TesterOpsIssue[]

  @@index([workspaceId, createdAt])
  @@index([eventId])
}

/// Junction: workspace members tagged as attendees on a manual-time
/// request. Composite PK prevents dupes; per-user index supports the
/// "show me everyone's meetings I was tagged in" query.
model MtrAttendee {
  requestId String
  request   ManualTimeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation("MtrAttendeeUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@id([requestId, userId])
  @@index([userId])
}

/// Junction: workspace members tagged as attendees on a TimeEntry (either
/// inherited from an approved MtrAttendee or retro-tagged on a live MEETING
/// segment). Same shape as MtrAttendee.
model TimeEntryAttendee {
  timeEntryId String
  timeEntry   TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("TeAttendeeUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([timeEntryId, userId])
  @@index([userId])
}

/// Content-free anti-cheat detection. One row per (user, window-start, type)
/// raised by the risk engine when activity samples are batch-uploaded.
/// `evidence` carries the engine's signal breakdown (rates, CVs, etc.) for
/// the dashboard's review queue — never key/text content.
enum FlagType {
  IMPOSSIBLE_RATE
  METRONOMIC
  LINEAR_MOUSE
  SINGLE_CHANNEL
  JIGGLER
}

enum FlagStatus {
  OPEN
  RESOLVED
}

enum FlagResolution {
  DISMISSED        // reviewer says the activity was legitimate
  CONFIRMED        // reviewer agrees it looks like cheating
  TIME_INVALIDATED // reviewer dropped the matching time (future hook)
}

model ActivityFlag {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation("FlagSubject", fields: [userId], references: [id])
  type         FlagType
  windowStart  DateTime       // start of the minute-window the engine assessed
  windowEnd    DateTime
  riskScore    Int            // 0–100 contribution from RISK_WEIGHTS[type]
  /// JSON keyed by signal name (eg ikiCv, pathStraightness, keysPerMin).
  /// Numbers only; the dashboard renders these as small read-only chips.
  evidence     Json
  status       FlagStatus     @default(OPEN)
  resolution   FlagResolution?
  resolvedById String?
  resolvedBy   User?          @relation("FlagResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?
  resolvedNote String?
  createdAt    DateTime       @default(now())
  timeInvalidation TimeInvalidation?

  /// Dedupe key: re-uploading the same window should not double-flag.
  @@unique([userId, windowStart, type])
  @@index([userId, status])
  @@index([status, createdAt])
}

/// Immutable audit record that removes a reviewed anti-cheat window from
/// counted totals without deleting raw TimeEntry/Screenshot/ActivitySample rows.
model TimeInvalidation {
  id              String       @id @default(cuid())
  workspaceId     String
  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  flagId          String       @unique
  flag            ActivityFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation("TimeInvalidationSubject", fields: [userId], references: [id], onDelete: Cascade)
  windowStart     DateTime
  windowEnd       DateTime
  invalidatedById String?
  invalidatedBy   User?        @relation("TimeInvalidationActor", fields: [invalidatedById], references: [id], onDelete: SetNull)
  reason          String
  createdAt       DateTime     @default(now())

  @@index([workspaceId, windowStart])
  @@index([userId, windowStart])
}

/// Immutable audit trail for screenshot/idle timing changes. This exists so
/// unusually aggressive monitoring settings are explainable after the fact.
model MonitoringSettingsAudit {
  id                            String                      @id @default(cuid())
  workspaceId                   String
  workspace                     Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorId                       String?
  actor                         User?                       @relation("MonitoringSettingsAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUserId                  String?
  targetUser                    User?                       @relation("MonitoringSettingsAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  scope                         MonitoringSettingsScope
  previousScreenshotIntervalMin Int?
  previousIdleThresholdMin      Int?
  previousIdleWarningSeconds    Int?
  nextScreenshotIntervalMin     Int?
  nextIdleThresholdMin          Int?
  nextIdleWarningSeconds        Int?
  riskLevel                     MonitoringSettingsRiskLevel
  reason                        String?
  createdAt                     DateTime                    @default(now())

  @@index([workspaceId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([actorId, createdAt])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String    @unique
  deviceName String?
  // Rotation family: every token minted by rotating an earlier one inherits the
  // same familyId. Presenting an already-revoked token (replay/theft) revokes
  // the whole family — OAuth 2.0 BCP refresh-token reuse detection.
  familyId   String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
}

/// Cached real app icons, keyed by macOS/Windows bundle id. Workspace-agnostic —
/// an app's icon is the same for everyone, so agents upload the PNG once per
/// bundle (idempotent upsert) and the insights API inlines it as a data URL.
model AppIcon {
  bundleId  String   @id
  app       String
  png       Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
